NODE_ENV=production
# Optional: override SQLite file path.
# Leave empty in development to use backend/data.sqlite by default.
# Example for Docker: /app/data/data.sqlite
SQLITE_PATH=
# Optional: local development only. Set to true to import backend/data.json on first empty-database startup.
# Production and Docker deployments should leave this unset and rely on minimal system initialization.
ALLOW_JSON_SEED=
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_SYSTEM_PROMPT_FILE=prompts/Prompt.md
DEEPSEEK_TIMEOUT_MS=90000
MODEL_CONCURRENCY=6
MODEL_QUEUE_MAX=50
MODEL_RETRY_MAX=2
MODEL_RETRY_BASE_MS=500
MODEL_KEY_COOLDOWN_MS=60000
